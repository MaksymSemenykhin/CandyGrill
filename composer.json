{
    "name": "candygrill/game-server",
    "description": "CandyGrill test assignment — game API server",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "ext-pdo": "*",
        "robmorgan/phinx": "^0.16.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.59",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-pdo_mysql": "MySQL driver for PDO (required to run migrations against MySQL)",
        "ext-memcached": "Optional; container image includes it for later session cache"
    },
    "autoload": {
        "psr-4": {
            "Game\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Game\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=256M",
        "cs-check": "php-cs-fixer fix --dry-run --diff --allow-risky=yes",
        "cs-fix": "php-cs-fixer fix --allow-risky=yes",
        "check": [
            "@cs-check",
            "@stan",
            "@test"
        ],
        "migrate": "php bin/migrate.php"
    }
}
