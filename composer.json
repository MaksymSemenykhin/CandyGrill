{
    "name": "candygrill/game-server",
    "description": "CandyGrill test assignment — game API server",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "suggest": {
        "ext-pdo": "Required from phase 1 onward (MySQL)",
        "ext-memcached": "Optional; container image includes it for later session cache"
    },
    "autoload": {
        "psr-4": {
            "Game\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Game\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit"
    }
}
