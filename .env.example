# Copy to .env for Docker Compose. Service names match hostnames inside the network.

APP_PORT=8080

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=candygrill
DB_USERNAME=root
DB_PASSWORD=password

FORWARD_DB_PORT=3306

MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211
FORWARD_MEMCACHED_PORT=11211

# Sessions: memory (default) or memcached (Docker: shared cache across processes).
SESSION_DRIVER=memory
SESSION_TTL_SECONDS=86400
# Development only: allows `session_issue` to mint tokens without login (Part 4). Use false in production.
SESSION_ALLOW_ISSUE=false
# Default: sessions stay in RAM (per PHP worker). Set a JSON path here only to share `memory` sessions on disk (php -S / flock), or use SESSION_DRIVER=memcached.
# SESSION_MEMORY_SYNC_FILE= (empty) = RAM only when the key is present in .env.
# SESSION_MEMORY_SYNC_FILE=/var/www/html/.data/session-memory.json

# Match pool for `find_opponents`: players indexed on `login`, grouped by character level, TTL ≈ session.
# memory + MATCH_POOL_SYNC_FILE — JSON + flock (default path: match-pool.json beside SESSION_MEMORY_SYNC_FILE).
# memcached: single key MATCH_POOL_MEMCACHED_KEY (concurrent writes may be last-write-wins; for strict semantics consider Redis + Lua).
MATCH_POOL_ENABLED=true
MATCH_POOL_DRIVER=memory
# MATCH_POOL_SYNC_FILE=.data/match-pool.json
# MATCH_POOL_DRIVER=memcached
# MATCH_POOL_MEMCACHED_KEY=cg:matchpool:entries

# Dev: when true, JSON `database_error` includes `error.detail` (PDO message). Server log always gets the message via error_log.
DEBUG=false

# API response language: `en` or `ru`. Overridden per request when `Accept-Language` contains `ru`.
APP_LANG=en
