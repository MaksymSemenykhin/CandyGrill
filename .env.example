# Copy to .env for Docker Compose. Service names match hostnames inside the network.

APP_PORT=8080

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=candygrill
DB_USERNAME=root
DB_PASSWORD=password

FORWARD_DB_PORT=3306

MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211
FORWARD_MEMCACHED_PORT=11211

# Sessions: memory (default, per PHP process) or memcached (requires ext-memcached).
SESSION_DRIVER=memory
SESSION_TTL_SECONDS=86400
# Development only: allows `session_issue` to mint tokens without login (Part 4). Use false in production.
SESSION_ALLOW_ISSUE=false
# Optional: when SESSION_DRIVER=memory, JSON file path (relative to cwd) shared across `php -S` requests.
# SESSION_MEMORY_SYNC_FILE=.data/session-memory.json

DEBUG=false
