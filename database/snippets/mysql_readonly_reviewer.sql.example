-- Пример: пользователь только для просмотра БД из phpMyAdmin (без INSERT/UPDATE/DELETE).
-- Выполните от root один раз, подставьте пароль и имя БД при необходимости.
--
-- docker compose exec mysql mysql -uroot -p"$DB_PASSWORD" < ...   (или через phpMyAdmin как root)

CREATE USER IF NOT EXISTS 'reviewer'@'%' IDENTIFIED BY 'ЗАМЕНИТЕ_ПАРОЛЬ';
GRANT SELECT ON `candygrill`.* TO 'reviewer'@'%';
FLUSH PRIVILEGES;

-- В .env для compose:
-- PMA_MYSQL_USER=reviewer
-- PMA_MYSQL_PASSWORD=ЗАМЕНИТЕ_ПАРОЛЬ
